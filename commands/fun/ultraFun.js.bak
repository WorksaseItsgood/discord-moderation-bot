  // High Low
  {
    data: new SlashCommandBuilder()
      .setName('highlow')
      .setDescription('Guess high or low')
      .addStringOption(o => o.setName('guess').setDescription('Your guess')
        .setChoices({ name: 'Higher', value: 'high' }, { name: 'Lower', value: 'low' }))
        .setRequired(true)),
    async execute(interaction) {
      const guess = interaction.options.getString('guess');
      const num = Math.floor(Math.random() * 100) + 1;
      
      const result = (guess === 'high' && num > 50) || (guess === 'low' && num <= 50) ? 'โ Correct!' : 'โ Wrong!';
      const embed = new EmbedBuilder()
        .setTitle('๐ฏ High Low')
        .setDescription(`Number: ${num}\nYour guess: ${guess}\n\n${result}`)
        .setColor(0x5865F2);
      
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  // RPS
  {
    data: new SlashCommandBuilder()
      .setName('rps')
      .setDescription('Rock paper scissors')
      .addStringOption(o => o.setName('choice').setDescription('Your choice')
        .setChoices({ name: 'Rock', value: 'rock' }, { name: 'Paper', value: 'paper' }, { name: 'Scissors', value: 'scissors' }))
        .setRequired(true)),
    async execute(interaction) {
      const choice = interaction.options.getString('choice');
      const bots = ['rock', 'paper', 'scissors'];
      const bot = bots[Math.floor(Math.random() * bots.length)];
      
      let result = 'draw';
      if ((choice === 'rock' && bot === 'scissors') || (choice === 'paper' && bot === 'rock') || (choice === 'scissors' && bot === 'paper')) {
        result = 'win';
      } else if ((bot === 'rock' && choice === 'scissors') || (bot === 'paper' && choice === 'rock') || (bot === 'scissors' && choice === 'paper')) {
        result = 'lose';
      }
      
      const embed = new EmbedBuilder()
        .setTitle('โโโ๏ธ RPS')
        .setDescription(`You: ${choice}\nBot: ${bot}\n\n${result === 'win' ? '๐ You win!' : result === 'lose' ? '๐ข You lose!' : '๐ค Draw!'}`)
        .setColor(result === 'win' ? 0x00FF00 : result === 'lose' ? 0xFF0000 : 0xFFFF00);
      
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  // Color info
  {
    data: new SlashCommandBuilder()
      .setName('color')
      .setDescription('Get color info')
      .addStringOption(o => o.setName('hex').setDescription('Hex code').setRequired(true)),
    async execute(interaction) {
      let hex = interaction.options.getString('hex').replace('#', '');
      if (!/^[0-9A-Fa-f]{6}$/.test(hex)) {
        return interaction.reply({ content: 'Invalid hex! Use #RRGGBB format', ephemeral: true });
      }
      hex = hex.toUpperCase();
      
      const embed = new EmbedBuilder()
        .setTitle('๐จ Color Info')
        .setDescription(`**Hex:** #${hex}\n**RGB:** ${parseInt(hex.substr(0,2),16)}, ${parseInt(hex.substr(2,2),16)}, ${parseInt(hex.substr(4,2),16)}`)
        .setColor(parseInt(hex, 16));
      
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  // Reverse text
  {
    data: new SlashCommandBuilder()
      .setName('reverse')
      .setDescription('Reverse text')
      .addStringOption(o => o.setName('text').setDescription('Text').setRequired(true)),
    async execute(interaction) {
      const text = interaction.options.getString('text');
      const reversed = text.split('').reverse().join('');
      
      await interaction.reply({ content: `๐ Reversed:\n${reversed}` });
    },
  },
  
  // Vaporwave
  {
    data: new SlashCommandBuilder()
      .setName('vaporwave')
      .setDescription('Convert text to vaporwave')
      .addStringOption(o => o.setName('text').setDescription('Text').setRequired(true)),
    async execute(interaction) {
      const text = interaction.options.getString('text');
      const fullwidth = '๏ผก๏ผข๏ผฃ๏ผค๏ผฅ๏ผฆ๏ผง๏ผจ๏ผฉ๏ผช๏ผซ๏ผฌ๏ผญ๏ผฎ๏ผฏ๏ผฐ๏ผฑ๏ผฒ๏ผณ๏ผด๏ผต๏ผถ๏ผท๏ผธ๏ผน๏ผบ';
      const lower = 'abcdefghijklmnopqrstuvwxyz';
      
      let converted = '';
      for (const char of text) {
        const idx = lower.indexOf(char);
        if (idx >= 0) converted += fullwidth[idx];
        else converted += char;
      }
      
      const embed = new EmbedBuilder()
        .setTitle('๐ Vaporwave')
        .setDescription(converted)
        .setColor(0xFF71CE);
      
      await interaction.reply({ embeds: [embed] });
    },
  },
  
