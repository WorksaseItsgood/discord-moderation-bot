  {
    data: new SlashCommandBuilder()
      .setName('roll')
      .setDescription('Roll dice')
      .addStringOption(o => o.setName('dice').setDescription('Dice (e.g., 2d6)')),
    async execute(interaction) {
      const dice = interaction.options.getString('dice') || '1d6';
      const match = dice.match(/(\d+)d(\d+)/);
      if (!match) {
        return interaction.reply({ content: 'Use format like 2d6', ephemeral: true });
      }
      const num = parseInt(match[1]);
      const sides = parseInt(match[2]);
      let total = 0;
      const rolls = [];
      for (let i = 0; i < num; i++) {
        const r = Math.floor(Math.random() * sides) + 1;
        rolls.push(r);
        total += r;
      }
      const embed = new EmbedBuilder()
        .setTitle('๐ฒ Roll')
        .setDescription(`**${dice}:** ${rolls.join(', ')} = ${total}`)
        .setColor(0x5865F2);
      await interaction.reply({ embeds: [embed] });
    },
  },
  
