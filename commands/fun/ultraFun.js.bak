const { SlashCommandBuilder, ActionRowBuilder, ButtonBuilder, ButtonStyle, EmbedBuilder } = require('discord.js');

const funCommands = [
  // 8ball with more responses
  {
    data: new SlashCommandBuilder()
      .setName('8ball')
      .setDescription('Ask the magic 8 ball')
      .addStringOption(o => o.setName('question').setDescription('Your question').setRequired(true)),
    async execute(interaction) {
      const responses = [
        'Yes!', 'No!', 'Maybe!', 'Definitely!', 'Absolutely not!',
        'Ask again later', 'Signs point to yes', 'Outlook good',
        'Very doubtful', 'Without a doubt', 'My sources say no',
        'Concentrate and ask again', 'Don\'t count on it',
        'It is certain', 'You may rely on it', 'Reply hazy, try again',
        'Yes - in due time', 'Better not tell you now', 'Definitely yes',
        'Absolutely', 'A million percent yes', 'Zero chance',
        '100% yes', '404 Not Found', '42', '42 is the answer',
        'The universe says yes!', 'The spirits say no...',
      ];
      const question = interaction.options.getString('question');
      const answer = responses[Math.floor(Math.random() * responses.length)];
      
      const embed = new EmbedBuilder()
        .setTitle('๐ฑ Magic 8 Ball')
        .setDescription(`**Q:** ${question}\n\n**A:** ${answer}`)
        .setColor(0x5865F2)
        .setTimestamp();
      
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  // Hack (fun)
  {
