  {
    data: new SlashCommandBuilder()
      .setName('ship')
      .setDescription('Ship two users')
      .addUserOption(o => o.setName('user1').setDescription('User 1').setRequired(true))
      .addUserOption(o => o.setName('user2').setDescription('User 2').setRequired(true)),
    async execute(interaction) {
      const u1 = interaction.options.getUser('user1');
      const u2 = interaction.options.getUser('user2');
      const percent = Math.floor(Math.random() * 100);
      const hearts = percent >= 70 ? '๐๐' : percent >= 40 ? '๐' : '๐';
      const embed = new EmbedBuilder()
        .setTitle('๐ Shipping')
        .setDescription(`${u1} x ${u2}\n**${percent}%** ${hearts}`)
        .setColor(0xFF69B4);
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  {
    data: new SlashCommandBuilder()
      .setName('slots')
      .setDescription('Slot machine'),
    async execute(interaction) {
      const symbols = ['๐', '๐', '๐', '๐', '๐', '๐'];
      const spin = () => symbols[Math.floor(Math.random() * symbols.length)];
      const row = [spin(), spin(), spin()];
      const win = row[0] === row[1] && row[1] === row[2];
      const embed = new EmbedBuilder()
        .setTitle('๐ฐ Slots')
        .setDescription(row.join(' '))
        .setDescription(`${row.join('  ')}\n\n${win ? '๐ JACKPOT!' : 'Try again!'}`)
        .setColor(win ? 0xFFD700 : 0x5865F2);
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  {
    data: new SlashCommandBuilder()
      .setName('trivia')
      .setDescription('Random trivia'),
    async execute(interaction) {
      const trivia = [
        { q: 'What planet is closest to the sun?', a: 'Mercury' },
        { q: 'What is the largest ocean?', a: 'Pacific' },
        { q: 'How many bones in human body?', a: '206' },
      ];
      const q = trivia[Math.floor(Math.random() * trivia.length)];
      const embed = new EmbedBuilder()
        .setTitle('โ Trivia')
        .setDescription(`**Q:** ${q.q}\n\n*A:* ||${q.a}||`)
        .setColor(0x5865F2);
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  {
    data: new SlashCommandBuilder()
      .setName('wouldyourather')
      .setDescription('Would you rather...'),
    async execute(interaction) {
      const questions = [
        'Infinite money or infinite time?',
        'Be invisible or read minds?',
        'Fight horse duck or 100 duck horses?',
      ];
      const embed = new EmbedBuilder()
        .setTitle('๐ค Would You Rather')
        .setDescription(questions[Math.floor(Math.random() * questions.length)])
        .setColor(0xFF6B6B);
      await interaction.reply({ embeds: [embed] });
    },
  },
  
  {
    data: new SlashCommandBuilder()
      .setName('zalgo')
      .setDescription('Zalgo text')
      .addStringOption(o => o.setName('text').setDescription('Text').setRequired(true)),
    async execute(interaction) {
      const text = interaction.options.getString('text');
      const zalgo = 'อกยฐอสอกยฐ';
      let result = text;
      for (const char of text) {
        result += char + zalgo[Math.floor(Math.random() * zalgo.length)];
      }
      await interaction.reply(result.substring(0, 2000));
    },
  },
  
  {
    data: new SlashCommandBuilder()
      .setName('compliment')
      .setDescription('Give a compliment')
      .addUserOption(o => o.setName('user').setDescription('User')),
    async execute(interaction) {
      const user = interaction.options.getUser('user') || interaction.user;
      const compliments = [
        'You\'re amazing!', 'You\'re doing great!', 'You\'re awesome!',
        'Keep it up!', 'You\'re a star!',
      ];
      await interaction.reply(`${user} ${compliments[Math.floor(Math.random() * compliments.length)]}`);
    },
  },
];

module.exports = funCommands;