      await interaction.reply(`๐งโ๐ป Hacking ${target}...`);
      
      for (let i = 0; i < steps.length; i++) {
        await new Promise(r => setTimeout(r, 600));
        await interaction.followUp({ content: steps[i], ephemeral: true });
      }
    },
  },
  
