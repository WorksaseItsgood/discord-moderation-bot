# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# MongoDB Connection (optional - uses JSON if not set)
MONGODB_URI=mongodb://localhost:27017/niotic

# Bot Configuration
PREFIX=!
BOT_NAME=Niotic
BOT_VERSION=3.0.0

# Owner IDs (comma separated)
OWNER_IDS=123456789,987654321

# Default Log Channel
LOG_CHANNEL=logs

# API Keys (optional)
API_KEY=

# Debug Mode
DEBUG=false
